# === App ===
APP_ENV=dev

# === Database ===
# Local:  postgresql+psycopg://postgres:postgres@localhost:5432/quant
# Neon:   postgresql+psycopg://user:pass@ep-xxx.us-east-2.aws.neon.tech/quant?sslmode=require
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/quant

# === Vector DB ===
# Local:  http://localhost:6333
# Cloud:  https://xxx-xxx.aws.cloud.qdrant.io:6333
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                  # required for Qdrant Cloud

# === Redis ===
# Local:  redis://localhost:6379/0
# Cloud:  rediss://default:xxx@us1-xxx.upstash.io:6379
REDIS_URL=redis://localhost:6379/0

# === News Ingestion ===
NEWS_POLL_INTERVAL_SECONDS=120
NEWS_SOURCES=rss:https://feeds.finance.yahoo.com/rss/2.0/headline?s=%5EGSPC&region=US&lang=en-US
MAX_DOCS_PER_POLL=50
DEDUP_CONTENT_HASH=sha256

# === Market Data ===
MARKET_DATA_PROVIDER=alpaca
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
MARKET_DATA_LOOKBACK_DAYS=365
BAR_TIMEFRAME=1Day

# === Embeddings & Vector DB ===
EMBEDDINGS_PROVIDER=mock
OPENAI_API_KEY=
VECTOR_COLLECTION=news
VECTOR_SIZE=1536
CHUNK_SIZE_CHARS=1000
CHUNK_OVERLAP_CHARS=150

# === LLM (RAG Agent) ===
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6

# === Sentiment ===
SENTIMENT_PROVIDER=finbert

# === Risk & Execution ===
RISK_MAX_GROSS_EXPOSURE=1.0
RISK_MAX_POSITION_PCT=0.10
RISK_MAX_DAILY_LOSS_PCT=0.02
RISK_MAX_TRADES_PER_HOUR=30
RISK_MAX_DATA_STALENESS_MINUTES=30
PAPER_INITIAL_CASH=100000
PAPER_GUARD=true
TRADING_MODE=paper
BROKER_PROVIDER=internal             # internal | alpaca

# === Strategy Agent ===
STRATEGY_MIN_CONFIDENCE=0.6
STRATEGY_MAX_DIFF_FIELDS=3
STRATEGY_MAX_ACTIVATIONS_PER_DAY=4
STRATEGY_MIN_BACKTEST_DAYS=252
STRATEGY_APPROVED_UNIVERSE=SPY,QQQ,AAPL,MSFT,AMZN,GOOGL,META,NVDA,BRK.B,JPM
PENDING_APPROVAL_AUTO_APPROVE_MINUTES=0

# === Backtest Cost Model ===
BACKTEST_COMMISSION_PER_TRADE=1.0
BACKTEST_SLIPPAGE_BPS=5.0
BACKTEST_SPREAD_BPS=2.0

# === Backtest Activation Thresholds ===
BACKTEST_MIN_SHARPE=0.5
BACKTEST_MAX_DRAWDOWN=0.25
BACKTEST_MIN_WIN_RATE=0.40

# === Multi-Agent (optional) ===
# JSON array of agent configs. Empty list = single-agent mode (backward compatible).
# Each agent gets its own news feeds, Qdrant collection, and strategy.
# For K8s: set one agent per pod via this env var.
# AGENT_CONFIGS=[{"name":"tech","strategy_name":"tech_momentum_v1","universe":["AAPL","MSFT","NVDA","GOOGL","META"],"news_sources":"rss:https://feeds.example.com/tech","qdrant_collection":"news_tech"},{"name":"finance","strategy_name":"fin_momentum_v1","universe":["JPM","BAC","GS","BRK.B"],"news_sources":"rss:https://feeds.example.com/finance","qdrant_collection":"news_finance"}]
AGENT_CONFIGS=[]
